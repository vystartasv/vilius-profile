---
import '../styles.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Vilius Vystartas | Senior Microsoft 365 Platform Engineer',
  description = 'Senior Microsoft 365 Platform Engineer focused on SharePoint, SPFx, Power Platform, Azure, and practical AI-enabled workflows.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
