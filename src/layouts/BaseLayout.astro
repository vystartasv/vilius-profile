---
import '../styles.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Vilius Vystartas | Senior Microsoft 365 Platform Engineer',
  description = 'Senior Microsoft 365 Platform Engineer focused on SharePoint, SPFx, Power Platform, Azure, and practical AI-enabled workflows.',
} = Astro.props;

const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.toString();
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Vilius Vystartas',
  jobTitle: 'Senior Microsoft 365 Platform Engineer',
  url: 'https://vystartasv.github.io/vilius-profile/',
  description,
  sameAs: [
    'https://www.linkedin.com/in/vystartas/',
    'https://github.com/vystartasv',
  ],
  knowsAbout: [
    'SharePoint Online',
    'SPFx',
    'Power Platform',
    'Power Apps',
    'Power Automate',
    'Azure Functions',
    'Microsoft Graph',
    'TypeScript',
    'Accessibility',
    'AI-assisted engineering workflows',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0ea5e9" />
    <meta name="author" content="Vilius Vystartas" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content="Vilius Vystartas" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="en_GB" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body>
    <slot />
  </body>
</html>
