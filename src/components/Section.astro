---
interface Props {
  id: string;
  kicker: string;
  title: string;
  intro?: string;
}

const { id, kicker, title, intro } = Astro.props;
---

<section id={id} class="grid gap-6" aria-labelledby="section-{id}">
  <div class="grid gap-3">
    <p id="section-{id}-kicker" class="kicker">{kicker}</p>
    <h2 id="section-{id}-heading" class="section-title">{title}</h2>
    {intro && <p id="section-{id}-intro" class="max-w-3xl text-lg leading-8 text-slate-600">{intro}</p>}
  </div>
  <slot />
</section>

---
