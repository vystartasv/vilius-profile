---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Admin | Vilius Vystartas">
  <main class="container mx-auto px-6 py-12">
    <div class="mb-8 flex items-center justify-between">
      <h1 class="text-4xl font-semibold text-white">Admin Dashboard</h1>
      
      <form action="/api/auth/logout" method="POST">
        <button
          type="submit"
          class="rounded-lg border border-white/15 px-5 py-2 text-sm text-slate-200 transition hover:border-cyan-300 hover:text-cyan-200"
        >
          Sign Out
        </button>
      </form>
    </div>
    
    <div id="admin-content" class="grid gap-6 lg:grid-cols-2">
      <div class="card p-6">
        <h2 class="mb-4 text-xl font-semibold text-white">Identity</h2>
        <dl id="identity-dl" class="grid gap-2 text-slate-300">
          <!-- Populated by JS -->
        </dl>
      </div>
      
      <div class="card p-6">
        <h2 class="mb-4 text-xl font-semibold text-white">Session Info</h2>
        <p class="text-slate-300">
          Authentication is working. This is a protected route that requires login.
        </p>
      </div>
    </div>
    
    <div id="login-redirect" class="hidden">
      <p class="text-slate-300">Redirecting to login...</p>
    </div>
  </main>
  
  <script>
    // Client-side auth check
    async function checkAuth() {
      try {
        const res = await fetch('/api/auth/me');
        if (!res.ok) {
          window.location.href = '/login?redirect=/admin';
          return;
        }
        const data = await res.json();
        if (!data.authenticated) {
          window.location.href = '/login?redirect=/admin';
          return;
        }
        
        // Populate identity
        const dl = document.getElementById('identity-dl');
        dl.innerHTML = `
          <div class="flex justify-between border-b border-white/10 py-2">
            <dt>Name</dt>
            <dd class="text-white">${data.identity.name}</dd>
          </div>
          <div class="flex justify-between border-b border-white/10 py-2">
            <dt>Email</dt>
            <dd class="text-white">${data.identity.email}</dd>
          </div>
          <div class="flex justify-between border-b border-white/10 py-2">
            <dt>Role</dt>
            <dd class="text-cyan-200">${data.identity.role}</dd>
          </div>
          <div class="flex justify-between py-2">
            <dt>ID</dt>
            <dd class="font-mono text-sm text-slate-400">${data.identity.id}</dd>
          </div>
        `;
      } catch {
        window.location.href = '/login?redirect=/admin';
      }
    }
    checkAuth();
  </script>
</BaseLayout>
