---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';

const [experience, projects, writing] = await Promise.all([
  getCollection('experience'),
  getCollection('projects'),
  getCollection('writing'),
]);

const featuredProjects = projects.filter(({ data }) => data.featured);
const focusAreas = [
  'SharePoint intranet and portal engineering',
  'SPFx web parts, extensions, and component governance',
  'Power Platform delivery across Power Apps, Automate, and governance',
  'Azure-backed integration patterns for Microsoft 365 solutions',
  'Practical AI-enabled workflows that reduce manual operations',
];
---

<BaseLayout>
  <main>
    <header class="card overflow-hidden bg-gradient-to-br from-cyan-50 to-slate-50">
      <div class="grid gap-10 px-8 py-10 md:grid-cols-[1.3fr_0.7fr] md:px-12 md:py-14">
        <div class="grid gap-6">
          <p class="kicker">Senior Microsoft 365 Platform Engineer</p>
          <div class="grid gap-4">
            <h1 class="text-5xl font-semibold tracking-tight text-slate-900 md:text-7xl">
              Vilius Vystartas
            </h1>
            <p class="max-w-3xl text-xl leading-9 text-slate-600 md:text-2xl">
              I design and ship Microsoft 365 solutions that are usable, governable, and grounded in real delivery outcomes, from SharePoint and SPFx through Power Platform, Azure, and AI-assisted workflows.
            </p>
          </div>
          <div class="flex flex-wrap gap-3 text-sm font-medium">
            <a class="rounded-full bg-cyan-600 px-5 py-3 text-white transition hover:bg-cyan-700" href="https://www.linkedin.com/in/vystartas/">LinkedIn</a>
            <a class="rounded-full border border-slate-300 px-5 py-3 text-slate-700 transition hover:border-cyan-600 hover:text-cyan-700" href="https://github.com/vystartasv">GitHub</a>
            <a class="rounded-full border border-slate-300 px-5 py-3 text-slate-700 transition hover:border-cyan-600 hover:text-cyan-700" href="mailto:vilius.vystartas@gmail.com">Email</a>
          </div>
        </div>
        <div class="card grid content-start gap-5 p-6 bg-white">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Core focus</p>
          <ul class="grid gap-3 text-base leading-7 text-slate-700">
            {focusAreas.map((area) => <li class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">{area}</li>)}
          </ul>
        </div>
      </div>
    </header>

    <Section
      id="experience"
      kicker="Experience"
      title="Platform engineering with delivery ownership"
      intro="Enterprise consulting focused on Microsoft 365 architecture, SPFx development, Power Platform governance, and Azure integration."
    >
      <div class="grid gap-5">
        {experience.map(({ data }) => (
          <article class="card grid gap-4 p-6 md:p-8">
            <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
              <div>
                <h3 class="text-2xl font-semibold text-slate-900">{data.title}</h3>
                <p class="text-lg text-cyan-600">{data.company}</p>
              </div>
              <p class="text-sm uppercase tracking-[0.18em] text-slate-500">{data.period}</p>
            </div>
            <p class="max-w-4xl text-lg leading-8 text-slate-600">{data.summary}</p>
            <ul class="grid gap-3 md:grid-cols-2">
              {data.highlights.map((item) => (
                <li class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-slate-700">{item}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </Section>

    <Section
      id="projects"
      kicker="Selected work"
      title="Solution patterns and delivery outcomes"
      intro="Reusable architectures and practical implementations for enterprise Microsoft 365 environments."
    >
      <div class="grid gap-5 lg:grid-cols-2">
        {featuredProjects.map(({ data }) => (
          <article class="card grid gap-5 p-6 md:p-8">
            <div class="grid gap-3">
              <h3 class="text-2xl font-semibold text-slate-900">{data.title}</h3>
              <p class="text-lg leading-8 text-slate-600">{data.summary}</p>
            </div>
            <div class="flex flex-wrap gap-2 text-sm">
              {data.stack.map((item) => <span class="rounded-full border border-cyan-200 bg-cyan-50 px-3 py-1.5 text-cyan-700">{item}</span>)}
            </div>
            <ul class="grid gap-3 text-slate-700">
              {data.outcomes.map((outcome) => <li class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">{outcome}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </Section>

    <Section
      id="writing"
      kicker="Writing"
      title="Notes and technical writing"
      intro="Selected articles and insights on Microsoft 365 platform engineering."
    >
      <div class="grid gap-5 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="card p-6 md:p-8">
          <div class="grid gap-4">
            {writing.length > 0 ? writing.map(({ data }) => (
              <article class="grid gap-2 border-b border-slate-200 pb-4 last:border-b-0 last:pb-0">
                <p class="text-sm uppercase tracking-[0.18em] text-slate-500">{data.published}</p>
                <h3 class="text-xl font-semibold text-slate-900">{data.title}</h3>
                <p class="leading-7 text-slate-600">{data.summary}</p>
                <a class="prose-link text-sm font-medium" href={data.href}>Read</a>
              </article>
            )) : (
              <p class="text-slate-500">Writing coming soon. Follow on LinkedIn for updates.</p>
            )}
          </div>
        </div>
        <aside class="card grid gap-4 p-6 md:p-8">
          <h3 class="text-2xl font-semibold text-slate-900">Get in touch</h3>
          <ul class="grid gap-3 text-slate-600">
            <li>Enterprise Microsoft 365 consulting and solution architecture</li>
            <li>SPFx development and component governance</li>
            <li>Power Platform strategy and implementation</li>
            <li>Azure integration and AI-enabled workflows</li>
          </ul>
          <a class="prose-link font-medium" href="mailto:vilius.vystartas@gmail.com">vilius.vystartas@gmail.com</a>
        </aside>
      </div>
    </Section>
  </main>
</BaseLayout>
