---
import BaseLayout from '../layouts/BaseLayout.astro';

const error = Astro.url.searchParams.get('error');
const redirect = Astro.url.searchParams.get('redirect') || '/';
---

<BaseLayout title="Login | Vilius Vystartas">
  <main class="flex min-h-screen items-center justify-center">
    <div class="card w-full max-w-md p-8">
      <h1 class="mb-6 text-3xl font-semibold text-white">Sign In</h1>
      
      {error && (
        <div class="mb-4 rounded-lg border border-red-400/30 bg-red-400/10 px-4 py-3 text-red-200">
          {error === 'invalid' ? 'Invalid email or password' : 'An error occurred. Please try again.'}
        </div>
      )}
      
      <form action="/api/auth/login" method="POST" class="grid gap-4">
        <input type="hidden" name="redirect" value={redirect} />
        
        <div>
          <label for="email" class="mb-1 block text-sm text-slate-300">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full rounded-lg border border-white/10 bg-slate-900/50 px-4 py-3 text-white placeholder-slate-500 focus:border-cyan-400 focus:outline-none"
            placeholder="admin@example.com"
          />
        </div>
        
        <div>
          <label for="password" class="mb-1 block text-sm text-slate-300">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            class="w-full rounded-lg border border-white/10 bg-slate-900/50 px-4 py-3 text-white placeholder-slate-500 focus:border-cyan-400 focus:outline-none"
            placeholder="••••••••"
          />
        </div>
        
        <button
          type="submit"
          class="mt-2 rounded-lg bg-cyan-400 px-6 py-3 font-medium text-slate-950 transition hover:bg-cyan-300"
        >
          Sign In
        </button>
      </form>
      
      <div class="mt-6 text-center text-sm text-slate-400">
        <p>Demo credentials:</p>
        <p class="mt-1 font-mono text-cyan-200">admin@example.com / admin123</p>
      </div>
    </div>
  </main>
</BaseLayout>
